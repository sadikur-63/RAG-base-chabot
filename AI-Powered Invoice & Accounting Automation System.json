    {
      "parameters": {
        "sendTo": "mdahadali6679@gmail.com",
        "subject": "=Your last Invoice Reports",
        "message": "=<!--\nSubject: Your Invoice Report\nPreheader: Invoice for {{ $json.name }} — view details inside\n--> \n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>Invoice</title>\n  <style>\n    /* Basic reset */\n    body,table,td{margin:0;padding:0;font-family:Arial, Helvetica, sans-serif;color:#333333}\n    img{border:0;display:block}\n    a{text-decoration:none;color:#1a73e8}\n\n    /* Container */\n    .email-wrapper{width:100%;background:#f4f6f8;padding:24px}\n    .email-content{max-width:680px;margin:0 auto;background:#ffffff;border-radius:8px;overflow:hidden}\n    .email-body{padding:24px}\n\n    /* Header */\n    .brand{padding:20px 24px;background:#0b74de;color:#ffffff}\n    .brand h1{margin:0;font-size:20px}\n\n    /* Invoice table */\n    .invoice-meta{width:100%;margin-top:16px;border-collapse:collapse}\n    .invoice-meta td{padding:8px 6px;vertical-align:top}\n    .invoice-table{width:100%;border-collapse:collapse;margin-top:18px}\n    .invoice-table th,.invoice-table td{padding:12px 10px;border-bottom:1px solid #e6e9ed;text-align:left}\n    .invoice-table th{background:#fafbfd;font-weight:600}\n    .total-row td{font-weight:700;padding-top:14px}\n\n    /* Footer */\n    .footer{font-size:12px;color:#8a8f97;padding:18px 24px}\n\n    /* Mobile */\n    @media only screen and (max-width:520px){\n      .email-body{padding:16px}\n      .brand h1{font-size:18px}\n      .invoice-table th,.invoice-table td{padding:10px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"email-wrapper\">\n    <div class=\"email-content\" role=\"article\" aria-label=\"Invoice\">\n\n      <!-- Header / Brand -->\n      <div class=\"brand\">\n        <table width=\"100%\"><tr><td>\n          <h1>{{ $json.property_company_name }}</h1>\n          <div style=\"font-size:13px;margin-top:6px;opacity:0.95\">Invoice report</div>\n        </td><td style=\"text-align:right;vertical-align:middle\">\n          <small style=\"opacity:0.9\">{{ $json.url }}</small>\n        </td></tr></table>\n      </div>\n\n      <!-- Body -->\n      <div class=\"email-body\">\n\n        <!-- Greeting -->\n        <p style=\"margin:0 0 14px 0\">Hi {{ $json.name }},</p>\n        <p style=\"margin:0 0 18px 0;color:#56606a\">Thank you for your business. Below is the invoice summary. If you have any questions, reply to this email ({{ $json.property_email }}).</p>\n\n        <!-- Invoice meta -->\n        <table class=\"invoice-meta\">\n          <tr>\n            <td style=\"width:60%\">\n              <strong>Invoice To</strong><br>\n              {{ $json.name }}<br>\n              {{ $json.property_email }}\n            </td>\n            <td style=\"width:40%\">\n              <strong>Invoice Details</strong><br>\n              <div>Service: {{ $json.property_desciption }}</div>\n              <div>Reference: <small>{{ $json.url }}</small></div>\n            </td>\n          </tr>\n        </table>\n\n        <!-- Line items / amounts -->\n        <table class=\"invoice-table\" role=\"table\" aria-label=\"Invoice items\">\n          <thead>\n            <tr>\n              <th style=\"width:60%\">Description</th>\n              <th style=\"width:20%\">Amount</th>\n              <th style=\"width:20%\">Notes</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr>\n              <td>{{ $json.property_desciption }}</td>\n              <td>{{ $json.property_amount }}</td>\n              <td>Base amount</td>\n            </tr>\n            <tr>\n              <td>Discount</td>\n              <td>{{ $json.property_discount }}</td>\n              <td>Applied discount</td>\n            </tr>\n            <tr>\n              <td>Service charge</td>\n              <td>{{ $json.property_service_charge }}</td>\n              <td>Service / processing</td>\n            </tr>\n\n            <!-- Total row: show a simple expression so your automation can compute if needed -->\n            <tr class=\"total-row\">\n              <td style=\"text-align:right\">Total</td>\n              <td colspan=\"2\">{{ $json.property_amount }} - {{ $json.property_discount }} + {{ $json.property_service_charge }}</td>\n            </tr>\n          </tbody>\n        </table>\n\n        <!-- CTA / link to full invoice -->\n        <p style=\"margin:18px 0 0 0\">View full invoice: <a href=\"{{ $json.url }}\">Open Invoice</a></p>\n\n        <!-- Notes -->\n        <hr style=\"margin:18px 0;border:none;border-top:1px solid #eef2f6\">\n        <p style=\"font-size:13px;color:#6b7280;margin:0\">Notes: {{ $json.property_desciption }}</p>\n\n      </div>\n\n      <!-- Footer -->\n      <div class=\"footer\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div>\n            <div><strong>{{ $json.property_company_name }}</strong></div>\n            <div>Contact: {{ $json.property_email }}</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div>Thank you for your business.</div>\n            <div style=\"font-size:12px;margin-top:6px;opacity:0.85\">This is an automated message — please do not reply to the sender address.</div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</body>\n</html>",
        "options": {}
      },
